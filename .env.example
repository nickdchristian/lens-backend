# Database Configuration
# Supported types: dynamodb, mongodb
DATABASE_TYPE=dynamodb

# --- DynamoDB Settings ---
DYNAMO_TABLE_NAME=LensEvents
AWS_REGION=us-east-1

# --- MongoDB Settings ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=lens

# Rate Limiting
RATE_LIMIT_EVENTS=100/minute
RATE_LIMIT_API=50/minute

# CORS
CORS_ORIGINS=["http://localhost:8080","http://localhost:8000"]
